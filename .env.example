# Email Configuration for Contact Form
# Configure these with your mailcow SMTP settings

# SMTP server settings
SMTP_HOST=steltner.cc
SMTP_PORT=587
# Use 587 for STARTTLS or 465 for SSL/TLS

# SMTP authentication
SMTP_USER=contact@steltner.cc
SMTP_PASS=your-secure-password-here

# Common mailcow SMTP ports:
# Port 587: STARTTLS (recommended)
# Port 465: SSL/TLS
# Port 25: Plain (usually blocked by ISPs)

# If using port 465 (SSL), change SMTP_PORT to 465
# If using port 587 (STARTTLS), use 587 (default)
