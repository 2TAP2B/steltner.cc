---
import Base from '../layouts/Base.astro'
---

<Base title="Danke - Steltner.cc">
  <div class="w-full min-h-screen flex flex-col justify-center items-center bg-gray-800 dark:bg-gray-900">
    <div class="self-center text-center w-full xl:w-1/2 px-4 sm:px-0">
      <div class="mb-8">
        <svg class="w-24 h-24 text-green-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <h1 class="font-bold tracking-widest text-gray-200 text-4xl mb-4">Danke für deine Nachricht! 🎉</h1>
      <div class="font-light text-gray-400 dark:text-gray-300 text-xl mb-8">
        <p class="mb-4">Deine Nachricht wurde erfolgreich gesendet.</p>
        <p class="mb-4">Ich melde mich unter <span class="text-purple-400">tobias@steltner.cc</span> so schnell wie möglich zurück.</p>
        <p>Normalerweise innerhalb von 24 Stunden, außer ich bin gerade mit Servern beschäftigt! 🤓</p>
      </div>
      <div class="mt-8">
        <a href="/" class="bg-purple-600 hover:bg-purple-700 dark:bg-purple-700 dark:hover:bg-purple-600 text-white font-bold py-3 px-6 rounded transition duration-300 ease-in-out transform hover:scale-105">
          Zurück zum Homelab
        </a>
      </div>
    </div>
  </div>
</Base>
