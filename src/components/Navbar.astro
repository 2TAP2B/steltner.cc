---
import siteData from '../data/site.json'

const pn = Astro.url.pathname
const isHome = pn === '/'
const site = Astro.site
const abtLink = isHome
  ? '#about'
  : `${site}#about`
const ftLink = isHome
  ? '#features'
  : `${site}#features`
const clLink = isHome
  ? '#contact-links'
  : `${site}#contact-links`
const regLink = isHome
  ? '#register'
  : `${site}#register`
---
<nav id="navbar" class="flex flex-col sm:flex-row w-full justify-between items-center px-4 sm:px-6 py-1 bg-white dark:bg-gray-800 shadow transition-transform duration-300 fixed top-0 left-0 right-0 z-50 transform translate-y-0">
  <div class="w-full sm:w-auto self-start sm:self-center flex flex-row sm:flex-none flex-no-wrap justify-between items-center">
    <a href={Astro.site} class="no-underline">
      <img src={`${site}img/logo.svg`} alt="Steltner.cc Logo" class="h-12 py-1 dark:filter dark:invert">
    </a>
    <button id="menuBtn" class="hamburger block sm:hidden focus:outline-none" type="button" onclick="navToggle();" aria-label="Show Menu">
      <span class="hamburger__top-bun dark:bg-gray-200"></span>
      <span class="hamburger__bottom-bun dark:bg-gray-200"></span>
    </button>
  </div>
  <div id="menu" class="w-full sm:w-auto self-end sm:self-center hidden sm:flex flex-col sm:flex-row items-center h-full py-1 pb-4 sm:py-0 sm:pb-0">
    <a class="text-gray-800 dark:text-gray-200 font-bold hover:text-purple-600 dark:hover:text-purple-400 text-lg text-center w-full no-underline sm:w-auto sm:pr-4 py-2 sm:py-1" href={abtLink}>about</a>
        <a class="text-gray-800 dark:text-gray-200 font-bold hover:text-purple-600 dark:hover:text-purple-400 text-lg text-center w-full no-underline sm:w-auto sm:px-4 py-2 sm:py-1" href={clLink}>connect</a>
    <a class="text-gray-800 dark:text-gray-200 font-bold hover:text-purple-600 dark:hover:text-purple-400 text-lg text-center w-full no-underline sm:w-auto sm:px-4 py-2 sm:py-1" href={ftLink}>features</a>

    {siteData.social.map((scm) => (
      <a href={scm.url} class="text-gray-800 dark:text-gray-200 font-bold hover:text-purple-600 dark:hover:text-purple-400 text-lg text-center w-full no-underline sm:hidden py-2" target="_blank" rel="noopener">{scm.title}</a>
    ))}

  </div>
</nav>
