---
interface Props {
  title: string
}

const { title } = Astro.props

const contactLinks = [
  {
    title: "Personal Blog",
    subtitle: "personal blog",
    url: "https://blog.steltner.cc", // Update with your actual blog URL
    icon: "link",
    bgColor: "bg-gray-700",
    hoverColor: "hover:bg-gray-600"
  },
  {
    title: "Mail",
    subtitle: "reach me out via mail",
    url: "mailto:tobias@steltner.cc",
    icon: "mail",
    bgColor: "bg-blue-600",
    hoverColor: "hover:bg-blue-500"
  },
  {
    title: "Music Blog",
    subtitle: "legacy blog project",
    url: "https://music.steltner.cc", // Update with your actual music blog URL
    icon: "music",
    bgColor: "bg-purple-600",
    hoverColor: "hover:bg-purple-500"
  },
  {
    title: "Matrix",
    subtitle: "Chat encrypted with Matrix",
    url: "https://matrix.to/#/@tobias:steltner.cc", // Update with your Matrix handle
    icon: "chat",
    bgColor: "bg-green-600",
    hoverColor: "hover:bg-green-500"
  },
  {
    title: "Mastodon",
    subtitle: "mastodon over x",
    url: "https://mastodon.social/@tobias", // Update with your Mastodon handle
    icon: "mastodon",
    bgColor: "bg-indigo-600",
    hoverColor: "hover:bg-indigo-500"
  },
  {
    title: "GitHub",
    subtitle: "github",
    url: "https://github.com/steltner", // Update with your GitHub username
    icon: "github",
    bgColor: "bg-gray-800",
    hoverColor: "hover:bg-gray-700"
  }
]
---

<div id="contact-links" class="w-full min-h-screen flex flex-col justify-center items-center bg-gray-100 py-16">
  <div class="self-center text-center w-full xl:w-2/3 px-4 sm:px-0">
    <h2 class="font-bold tracking-widest text-gray-800 text-4xl mb-4">{title}</h2>
    <div class="font-light text-gray-600 text-xl mb-12">
      <slot />
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {contactLinks.map((link) => (
        <a 
          href={link.url}
          target={link.url.startsWith('mailto:') ? '_self' : '_blank'}
          rel={link.url.startsWith('mailto:') ? '' : 'noopener noreferrer'}
          class={`${link.bgColor} ${link.hoverColor} text-white rounded-lg p-6 flex items-center space-x-4 transition-all duration-300 transform hover:scale-105 hover:shadow-lg`}
        >
          <div class="flex-shrink-0">
            {link.icon === 'link' && (
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14,3V5H17.59L7.76,14.83L9.17,16.24L19,6.41V10H21V3M19,19H5V5H12V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V12H19V19Z" />
              </svg>
            )}
            {link.icon === 'mail' && (
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" />
              </svg>
            )}
            {link.icon === 'music' && (
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,3V13.55C11.41,13.21 10.73,13 10,13A4,4 0 0,0 6,17A4,4 0 0,0 10,21A4,4 0 0,0 14,17V7H18V5H12V3Z" />
              </svg>
            )}
            {link.icon === 'chat' && (
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,3C6.5,3 2,6.58 2,11A7.18,7.18 0 0,0 2.64,14.25L1,22L8.75,20.36C9.88,20.75 11.05,21 12,21C17.5,21 22,17.42 22,13S17.5,3 12,3M12,19C11.27,19 10.56,18.82 9.91,18.5L9.5,18.27L5.27,19.45L6.45,15.23L6.22,14.82C5.9,14.17 5.72,13.46 5.72,12.72C5.72,9.39 8.39,6.72 11.72,6.72C15.05,6.72 17.72,9.39 17.72,12.72C17.72,16.05 15.05,18.72 11.72,18.72" />
              </svg>
            )}
            {link.icon === 'mastodon' && (
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.94,14C20.66,15.41 18.5,16.96 15.97,17.26C14.66,17.41 13.37,17.56 12,17.5C9.75,17.39 8,16.96 8,16.96V17.58C8.32,19.8 10.22,19.93 12.03,20C13.85,20.05 15.47,19.54 15.47,19.54L15.73,21.75S14.17,22.39 12,22.5C10.71,22.56 9.08,22.47 7.11,21.85C2.74,20.45 1.78,15.74 1.55,10.86C1.48,9.4 1.56,8.04 1.56,6.9C1.56,2.32 4.37,0.89 4.37,0.89C5.77,0.18 8.54,0 11.3,0H11.44C14.2,0 17,0.18 18.38,0.89C18.38,0.89 21.19,2.32 21.19,6.9C21.19,6.9 21.24,10.27 20.94,14M17.96,6.6C17.96,5.6 17.67,4.8 17.09,4.2C16.5,3.6 15.68,3.3 14.64,3.3C13.43,3.3 12.5,3.7 11.85,4.5L11.1,5.5L10.35,4.5C9.7,3.7 8.77,3.3 7.56,3.3C6.52,3.3 5.7,3.6 5.11,4.2C4.53,4.8 4.24,5.6 4.24,6.6V10.9H6.66V6.8C6.66,5.8 7.12,5.3 8.04,5.3C9.05,5.3 9.55,5.9 9.55,7.1V9.5H12.65V7.1C12.65,5.9 13.15,5.3 14.16,5.3C15.08,5.3 15.54,5.8 15.54,6.8V10.9H17.96V6.6Z" />
              </svg>
            )}
            {link.icon === 'github' && (
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z" />
              </svg>
            )}
          </div>
          <div class="flex-1 text-left">
            <h3 class="font-bold text-lg">{link.title}</h3>
            <p class="text-sm opacity-90">{link.subtitle}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>
