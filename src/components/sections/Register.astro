---
interface Props {
  title: string
}

const { title } = Astro.props
---
<div id="register" class="w-full min-h-screen flex flex-col justify-center items-center bg-gray-800 dark:bg-gray-900">
  <div class="self-center text-center w-full xl:w-1/2 px-4 sm:px-0">
    <h2 class="font-bold tracking-widest text-gray-200 text-4xl mb-4">{title}</h2>
    <div class="font-light text-gray-400 dark:text-gray-300 text-xl">
      <slot />
    </div>
    <form class="w-full max-w-2xl my-20 mx-auto" action="/api/contact" method="POST" id="contact-form">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <input 
            class="appearance-none bg-transparent border border-gray-600 dark:border-gray-500 w-full text-gray-200 focus:outline-none focus:bg-gray-700 dark:focus:bg-gray-800 focus:text-gray-200 focus:border-purple-600 dark:focus:border-purple-400 py-3 px-4 rounded" 
            type="text" 
            name="name" 
            placeholder="Your Name" 
            required
          >
        </div>
        <div>
          <input 
            class="appearance-none bg-transparent border border-gray-600 dark:border-gray-500 w-full text-gray-200 focus:outline-none focus:bg-gray-700 dark:focus:bg-gray-800 focus:text-gray-200 focus:border-purple-600 dark:focus:border-purple-400 py-3 px-4 rounded" 
            type="email" 
            name="email" 
            placeholder="your.email@example.com" 
            required
          >
        </div>
      </div>
      <div class="mb-4">
        <input 
          class="appearance-none bg-transparent border border-gray-600 dark:border-gray-500 w-full text-gray-200 focus:outline-none focus:bg-gray-700 dark:focus:bg-gray-800 focus:text-gray-200 focus:border-purple-600 dark:focus:border-purple-400 py-3 px-4 rounded" 
          type="text" 
          name="subject" 
          placeholder="Subject" 
          required
        >
      </div>
      <div class="mb-6">
        <textarea 
          class="appearance-none bg-transparent border border-gray-600 dark:border-gray-500 w-full text-gray-200 focus:outline-none focus:bg-gray-700 dark:focus:bg-gray-800 focus:text-gray-200 focus:border-purple-600 dark:focus:border-purple-400 py-3 px-4 rounded h-32 resize-none" 
          name="message" 
          placeholder="Your message about self-hosting, tech, or just to say hi..." 
          required
        ></textarea>
      </div>
      <button 
        class="w-full bg-purple-600 hover:bg-purple-700 dark:bg-purple-700 dark:hover:bg-purple-600 text-white font-bold py-3 px-6 rounded transition duration-300 ease-in-out transform hover:scale-105" 
        type="submit"
      >
        Send Message
      </button>
      <div class="mt-4 text-center">
        <p class="text-gray-400 dark:text-gray-300 text-sm">
          By sending this message, you agree to our <a href="/privacy" class="underline hover:no-underline hover:text-purple-600 dark:hover:text-purple-400" title="Privacy Policy" target="_blank">Privacy Policy</a>
        </p>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', function(e) {
    const button = this.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (button) {
      button.textContent = 'Sending...';
      button.disabled = true;
    }
  });
</script>
