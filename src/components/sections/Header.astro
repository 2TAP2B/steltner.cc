---
const headerListItems = [
  'Self-Hosted Email Server',
  'Matrix Chat',
  'Mastodon Network',
  'File Sharing',
  '100% Open Source',
  'Privacy Focused'
]
const site = Astro.site
---
<header id="top" class="header w-full min-h-screen flex flex-col justify-between pt-16">
  <div class="flex flex-col justify-center h-full py-12">
    <div class="self-center items-center flex flex-col sm:flex-row w-full md:w-5/6 xl:w-2/3 px-4 sm:px-0">
      <div class="w-full text-center sm:text-left sm:w-1/2 py-12 sm:px-8">
        <h1 class="tracking-wide text-purple-600 dark:text-purple-400 text-2xl mb-6">
          STELTNER.CC <span class="text-gray-800 dark:text-gray-200 font-bold tracking tracking-widest">Für digitale Souveränität</span>
        </h1>
        <h2 class="font-bold tracking-widest text-4xl text-gray-800 dark:text-gray-200">
          Frei, offen, selbst gehostet
        </h2>
        <span class="content__container block font-light text-browngray dark:text-gray-300 text-2xl my-6">
          <ul class="content__container__list">
            {headerListItems.map((item) => <li class="content__container__list__item xl:pl-3">{item}</li>)}
          </ul>
        </span>
        <p class="font-bold tracking-widest text-4xl text-gray-800 dark:text-gray-200">...because why not?</p>
      </div>
      <div class="w-full sm:w-1/2">
        <img src={`${site}img/undraw_digital-nomad_xr4.svg`} alt="Steltner.cc Email Hosting">
      </div>
    </div>
  </div>
  <div class="flex flex-row w-full justify-center pb-12">
    <a class="px-10 py-2 text-gray-200 bg-purple-600 rounded-full shadow-md text-lg hover:bg-gray-800 hover:border-red" href="#about">
      Erfahre mehr
    </a>
  </div>
</header>
